{{#if mobs}}

  <table class="ui unstackable striped table">
    <thead>
      <tr>
        <th>Title</th>
        <th>Mobs</th>
      </tr>
    </thead>
    <tbody>
      {{#each mobs}}
        <tr>
          <td>
            {{title}}
          </td>
          <td>
            {{type}}
          </td>
        </tr>
      {{/each}}
    </tbody>
  </table>

  {{else}}
    <h3 class="ui message">
      Empty Biome!
    </h3>

{{/if}}
