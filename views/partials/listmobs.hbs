{{#if mobs}}

  <table class="ui unstackable striped table">
    <thead>
      <tr>
        <th>Title</th>
        <th>Mobs</th>
      </tr>
    </thead>
    <tbody>
      {{#each mobs}}
        <tr>
          <td>
            {{title}}
          </td>
          <td>
            {{type}}
          </td>
          <td class="center aligned">
    <a href="/biome/{{../id}}/deletemob/{{id}}" 
	        title="Delete mob">
            <i class="ui pink trash icon"></i>
    </a>
</td>
        </tr>
      {{/each}}
    </tbody>
  </table>

  {{else}}
    <h3 class="ui message">
      Empty Biome!
    </h3>

{{/if}}
