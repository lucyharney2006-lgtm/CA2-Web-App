<form class="ui stacked segment form" action="/dashboard/addbiome" method="POST" enctype="multipart/form-data">
  <div class="field">
    <label>Title</label>
    <input placeholder="Title" type="text" name="title" autofocus required>
  </div>

  <div class="field">
  <label>Difficulty Rating</label>
  <select name="rating" required>
    <option value="">Select rating</option>
    <option value="1">1</option>
    <option value="2">2</option>
    <option value="3">3</option>
    <option value="4">4</option>
    <option value="5">5</option>
  </select>
</div>

<div class="field">
    <label>Image</label>
    <input placeholder="Image" type="file" name="picture" required>
</div>


 <button class="ui blue submit button">Add Biome</button>
</form>
